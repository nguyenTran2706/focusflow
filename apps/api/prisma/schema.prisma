// FocusFlow — API data model
// Read-first pass: auth + workspaces (milestone 1) plus all Kanban tables
// scaffolded now so milestone 2 doesn't need a second migration wave.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Identity ────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  clerkId        String    @unique
  email          String    @unique
  name           String
  imageUrl       String?
  phone          String?
  addressStreet  String?
  addressCity    String?
  addressState   String?
  addressPostal  String?
  addressCountry String?
  role           UserRole  @default(USER)
  subscription   SubTier   @default(FREE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  memberships    Membership[]
  invitesSent    Invite[]       @relation("InviteSender")
  cardsAuthored  Card[]         @relation("CardAuthor")
  cardsAssigned  Card[]         @relation("CardAssignee")
  comments       Comment[]
  chats          Chat[]
}

enum UserRole {
  USER
  ADMIN
}

enum SubTier {
  FREE
  PRO
  PRO_MAX
}

// Used for Stripe webhook idempotency — prevents duplicate event processing
model ProcessedEvent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId   String   @unique
  type      String
  createdAt DateTime @default(now())
}

// ─── Tenancy ────────────────────────────────────────────────────────────────

model Workspace {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  name                 String
  slug                 String   @unique
  plan                 Plan     @default(FREE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  memberships Membership[]
  boards      Board[]
  invites     Invite[]
}

enum Plan {
  FREE
  PRO
  TEAM
}

model Membership {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  workspaceId    String   @db.ObjectId
  role           Role     @default(MEMBER)
  createdAt      DateTime @default(now())
  lastAccessedAt DateTime? @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@index([userId, lastAccessedAt])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

model Invite {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  email       String
  token       String    @unique
  workspaceId String    @db.ObjectId
  role        Role      @default(MEMBER)
  invitedById String    @db.ObjectId
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
}

// ─── Kanban / Scrum ─────────────────────────────────────────────────────────

model Board {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  workspaceId String   @db.ObjectId
  name        String
  linkAccess  WhiteboardLinkAccess @default(NONE)
  linkToken   String   @unique @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastAccessedAt DateTime? @default(now())

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  columns     BoardColumn[]
  sprints     Sprint[]
  whiteboards Whiteboard[]
  diagrams    Diagram[]
  collaborators BoardCollaborator[]
  invitations   BoardInvitation[]

  @@index([workspaceId])
}

model BoardCollaborator {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  boardId   String         @db.ObjectId
  userId    String         @db.ObjectId
  role      WhiteboardRole @default(EDITOR)
  addedById String         @db.ObjectId
  createdAt DateTime       @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
}

model BoardInvitation {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  boardId     String         @db.ObjectId
  email       String
  role        WhiteboardRole @default(EDITOR)
  token       String         @unique @default(cuid())
  invitedById String         @db.ObjectId
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime       @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
  @@index([email])
}

model Sprint {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  boardId   String       @db.ObjectId
  name      String
  goal      String?
  startDate DateTime
  endDate   DateTime
  status    SprintStatus @default(PLANNING)
  velocity  Int?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId])
}

enum SprintStatus {
  PLANNING
  ACTIVE
  COMPLETED
}

model BoardColumn {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  boardId   String   @db.ObjectId
  name      String
  // fractional-rank string for cheap reorder without renumbering neighbours
  rank      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId, rank])
}

model Card {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  columnId    String    @db.ObjectId
  authorId    String    @db.ObjectId
  assigneeId  String?   @db.ObjectId
  sprintId    String?   @db.ObjectId
  title       String
  body        String?
  type        String    @default("task")
  priority    String?
  labels      String[]
  storyPoints Int?
  dueDate     DateTime?
  startDate   DateTime?
  rank        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  column   BoardColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  author   User        @relation("CardAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  assignee User?       @relation("CardAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  sprint   Sprint?     @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  comments Comment[]

  @@index([columnId, rank])
  @@index([assigneeId])
  @@index([sprintId])
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  cardId    String   @db.ObjectId
  authorId  String   @db.ObjectId
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  card   Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

// ─── Whiteboard & Diagrams ──────────────────────────────────────────────────

model Whiteboard {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  boardId     String   @db.ObjectId
  board       Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name        String   @default("Untitled Whiteboard")
  scene       Json     @default("{}")
  createdById String   @db.ObjectId
  linkAccess  WhiteboardLinkAccess @default(NONE)
  linkToken   String   @unique @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  collaborators WhiteboardCollaborator[]
  invitations   WhiteboardInvitation[]

  @@index([boardId])
}

enum WhiteboardRole {
  VIEWER
  EDITOR
}

enum WhiteboardLinkAccess {
  NONE
  VIEW
  EDIT
}

model WhiteboardCollaborator {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  whiteboardId String         @db.ObjectId
  userId       String         @db.ObjectId
  role         WhiteboardRole @default(EDITOR)
  addedById    String         @db.ObjectId
  createdAt    DateTime       @default(now())

  whiteboard Whiteboard @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)

  @@unique([whiteboardId, userId])
  @@index([userId])
}

model WhiteboardInvitation {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  whiteboardId String         @db.ObjectId
  email        String
  role         WhiteboardRole @default(EDITOR)
  token        String         @unique @default(cuid())
  invitedById  String         @db.ObjectId
  expiresAt    DateTime
  acceptedAt   DateTime?
  createdAt    DateTime       @default(now())

  whiteboard Whiteboard @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)

  @@index([whiteboardId])
  @@index([email])
}

model Diagram {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  boardId     String   @db.ObjectId
  board       Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  name        String   @default("Untitled Diagram")
  data        Json     @default("{}")
  createdById String   @db.ObjectId
  linkAccess  WhiteboardLinkAccess @default(NONE)
  linkToken   String   @unique @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  collaborators DiagramCollaborator[]
  invitations   DiagramInvitation[]

  @@index([boardId])
}

model DiagramCollaborator {
  id         String         @id @default(auto()) @map("_id") @db.ObjectId
  diagramId  String         @db.ObjectId
  userId     String         @db.ObjectId
  role       WhiteboardRole @default(EDITOR)
  addedById  String         @db.ObjectId
  createdAt  DateTime       @default(now())

  diagram Diagram @relation(fields: [diagramId], references: [id], onDelete: Cascade)

  @@unique([diagramId, userId])
  @@index([userId])
}

model DiagramInvitation {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  diagramId   String         @db.ObjectId
  email       String
  role        WhiteboardRole @default(EDITOR)
  token       String         @unique @default(cuid())
  invitedById String         @db.ObjectId
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime       @default(now())

  diagram Diagram @relation(fields: [diagramId], references: [id], onDelete: Cascade)

  @@index([diagramId])
  @@index([email])
}

// ─── FAQ (AI Chatbot knowledge base) ────────────────────────────────────────

model Faq {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  question  String
  answer    String
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Live Chat ──────────────────────────────────────────────────────────────

model Chat {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  userId    String     @db.ObjectId
  status    ChatStatus @default(BOT)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId])
}

enum ChatStatus {
  BOT
  WAITING_HUMAN
  HUMAN
  CLOSED
}

model ChatMessage {
  id         String      @id @default(auto()) @map("_id") @db.ObjectId
  chatId     String      @db.ObjectId
  senderId   String?     @db.ObjectId
  senderRole SenderRole
  body       String
  createdAt  DateTime    @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
}

enum SenderRole {
  USER
  BOT
  ADMIN
}
