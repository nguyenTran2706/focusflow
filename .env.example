# Copy to .env and fill in real values. Never commit .env.

# ---- MongoDB ----
DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/focusflow?retryWrites=true&w=majority

# ---- API (apps/api) ----
API_PORT=3001
AI_WORKER_URL=http://localhost:3002
CORS_ORIGIN=http://localhost:5173

# ---- Clerk (Auth) — https://dashboard.clerk.com ----
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# ---- AI Worker (apps/ai-worker) ----
AI_WORKER_PORT=3002
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Stripe (Payment) — https://dashboard.stripe.com ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_PRO=price_xxx
STRIPE_PRICE_ID_PRO_MAX=price_xxx
VITE_STRIPE_PRICE_ID_PRO=price_xxx
VITE_STRIPE_PRICE_ID_PRO_MAX=price_xxx

# ---- Pusher (Real-time) ----
PUSHER_APP_ID=xxx
PUSHER_KEY=xxx
PUSHER_SECRET=xxx
PUSHER_CLUSTER=us2
VITE_PUSHER_KEY=xxx
VITE_PUSHER_CLUSTER=us2

# ---- Web (apps/web) ----
# Local dev: leave empty (Vite proxy handles /api → localhost:3001)
# Production: set to your deployed API URL (e.g. https://api.focusflow.app)
VITE_API_URL=
